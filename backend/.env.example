# PORT: Server port (default: 8080)
PORT=8080

# CORS_ORIGIN: Allowed origins for CORS (default: *)
# In production, set this to your frontend URL
# Example: https://odd-hunt.vercel.app
CORS_ORIGIN=*

# SERVE_STATIC: Set to "true" if backend should serve frontend static files (default: false)
# Set this to "true" only if you're running a monolithic deployment (e.g., Render only)
# Leave unset/false if deploying frontend separately (e.g., Vercel)
SERVE_STATIC=false
